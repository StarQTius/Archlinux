#!/bin/fish

while true
  sleep 60
  if test 1 -le (date +'%w') -a (date +'%w') -le 5 -a 6 -le (date +'%k') -a (date +'%k') -lt 20
    logger "Timekeeper: allowing use"
  else if test \( (date +'%w') -eq 6 -o (date +'%w') -eq 0 \) -a 6 -le (date +'%k') -a (date +'%k') -lt 22
    logger "Timekeeper: allowing use"
  else
    poweroff
  end
end
