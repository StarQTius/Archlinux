#!/bin/fish

argparse -- $argv

if test (count $argv) -eq 0
  set file (find \
  | xargs --max-lines=1 --max-procs=(nproc) file --extension \
  | grep "pdf\$" \
  | sed 's/^\(.*\):\s*pdf$/\1/' \
  | fzf)
else if test (count $argv) -eq 1
  echo $argv | read file
else
  echo "Too many positional arguments (max 1)"
  exit 1
end

if test -z $file
  echo "No file selected"
  exit 1
end

if test ! (file $file | grep "PDF document")
  echo "$file is not a PDF file"
  exit 1
end

zathura $file &disown
